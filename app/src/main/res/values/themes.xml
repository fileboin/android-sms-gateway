<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- ================================================================
         Theme.SmsGateway — DeFi dark theme (forced dark, always-on)
         Parent uses DayNight so both variants are overridden below.
         ================================================================ -->
    <style name="Theme.SmsGateway" parent="Theme.MaterialComponents.DayNight.NoActionBar">

        <!-- Primary brand: orange -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/on_accent</item>

        <!-- Secondary: same orange family -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/on_accent</item>

        <!-- Backgrounds -->
        <item name="android:windowBackground">@drawable/bg_grid</item>
        <item name="android:colorBackground">@color/bg_primary</item>

        <!-- Surface (cards, sheets, dialogs) -->
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Error -->
        <item name="colorError">@color/status_error</item>
        <item name="colorOnError">@color/white</item>

        <!-- Text -->
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>

        <!-- System bars — dark -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/bg_primary</item>
        <item name="android:navigationBarColor" tools:targetApi="lollipop">@color/bg_secondary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>

        <!-- Ripple / control highlight -->
        <item name="colorControlHighlight">#33FF6B35</item>
        <item name="rippleColor">@color/accent</item>

        <!-- Shape appearances -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.SMSpeer.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.SMSpeer.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.SMSpeer.Large</item>

        <!-- Widget overrides -->
        <item name="materialCardViewStyle">@style/Widget.SMSpeer.CardView</item>
        <item name="materialButtonStyle">@style/Widget.SMSpeer.Button.Primary</item>
        <item name="materialButtonOutlinedStyle">@style/Widget.SMSpeer.Button.Outlined</item>
        <item name="textInputStyle">@style/Widget.SMSpeer.TextInputLayout</item>
        <item name="tabStyle">@style/Widget.SMSpeer.TabLayout</item>
        <item name="switchStyle">@style/Widget.SMSpeer.Switch</item>
        <item name="checkboxStyle">@style/Widget.SMSpeer.Checkbox</item>

        <!-- Toolbar / action bar -->
        <item name="actionBarTheme">@style/ThemeOverlay.SMSpeer.ActionBar</item>
        <item name="toolbarStyle">@style/Widget.SMSpeer.Toolbar</item>

        <!-- List divider color -->
        <item name="android:listDivider">@color/divider</item>

        <!-- Progress / seek bar -->
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlNormal">@color/text_secondary</item>
    </style>

    <!-- ================================================================
         Shape appearances
         ================================================================ -->
    <style name="ShapeAppearance.SMSpeer.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="ShapeAppearance.SMSpeer.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="ShapeAppearance.SMSpeer.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">20dp</item>
    </style>

    <!-- ================================================================
         Cards
         ================================================================ -->
    <style name="Widget.SMSpeer.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
        <item name="contentPaddingLeft">12dp</item>
        <item name="contentPaddingRight">12dp</item>
        <item name="contentPaddingTop">12dp</item>
        <item name="contentPaddingBottom">12dp</item>
    </style>

    <!-- ================================================================
         Buttons
         ================================================================ -->
    <style name="Widget.SMSpeer.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/accent</item>
        <item name="android:textColor">@color/on_accent</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">#40FFFFFF</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="Widget.SMSpeer.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/accent</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="rippleColor">#22FF6B35</item>
    </style>

    <style name="Widget.SMSpeer.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/accent</item>
        <item name="rippleColor">#22FF6B35</item>
    </style>

    <!-- ================================================================
         TextInputLayout
         ================================================================ -->
    <style name="Widget.SMSpeer.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxStrokeColor">@color/divider</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="android:textColorHint">@color/text_hint</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- ================================================================
         TabLayout (top navigation)
         ================================================================ -->
    <style name="Widget.SMSpeer.TabLayout" parent="Widget.MaterialComponents.TabLayout">
        <item name="android:background">@color/bg_secondary</item>
        <item name="tabTextColor">@color/text_secondary</item>
        <item name="tabSelectedTextColor">@color/accent</item>
        <item name="tabIndicatorColor">@color/accent</item>
        <item name="tabIndicatorHeight">3dp</item>
        <item name="tabIndicatorFullWidth">false</item>
        <item name="tabRippleColor">#22FF6B35</item>
        <item name="tabIconTint">@color/selector_tab_icon</item>
        <item name="tabTextAppearance">@style/TextAppearance.SMSpeer.Tab</item>
    </style>

    <style name="TextAppearance.SMSpeer.Tab" parent="TextAppearance.Design.Tab">
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:textSize">12sp</item>
    </style>

    <!-- ================================================================
         Switch
         ================================================================ -->
    <style name="Widget.SMSpeer.Switch" parent="Widget.MaterialComponents.CompoundButton.Switch">
        <item name="thumbTint">@color/selector_switch_thumb</item>
        <item name="trackTint">@color/selector_switch_track</item>
    </style>

    <!-- ================================================================
         Checkbox
         ================================================================ -->
    <style name="Widget.SMSpeer.Checkbox" parent="Widget.MaterialComponents.CompoundButton.CheckBox">
        <item name="buttonTint">@color/selector_checkbox_tint</item>
    </style>

    <!-- ================================================================
         Toolbar / ActionBar
         ================================================================ -->
    <style name="ThemeOverlay.SMSpeer.ActionBar" parent="ThemeOverlay.MaterialComponents.Dark.ActionBar">
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="colorControlNormal">@color/text_primary</item>
    </style>

    <style name="Widget.SMSpeer.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/bg_secondary</item>
        <item name="titleTextColor">@color/text_primary</item>
    </style>

    <!-- ================================================================
         Text styles (used in layouts by name)
         ================================================================ -->
    <style name="HomeCardLabel" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">start</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textAppearance">@style/TextAppearance.MaterialComponents.Body2</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="HomeCardValue" parent="Widget.AppCompat.TextView">
        <item name="android:lines">1</item>
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_gravity">start</item>
        <item name="android:layout_margin">4dp</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <!-- ================================================================
         Status badge — used in message/log list items
         ================================================================ -->
    <style name="StatusBadge" parent="Widget.AppCompat.TextView">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:paddingHorizontal">6dp</item>
        <item name="android:paddingVertical">2dp</item>
        <item name="android:textSize">11sp</item>
        <item name="android:background">@drawable/badge_background</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>


</resources>
